---
// 頁尾 —— 放聯絡方式與社群連結。Phase 5 換成你真正的連結。
const links = [
	{ label: "Email", href: "mailto:sullivan.hsu@ubitech.com.tw" },
	{ label: "Instagram", href: "#" },
	{ label: "Behance", href: "#" },
	{ label: "LinkedIn", href: "#" },
];
const year = new Date().getFullYear();
---

<footer id="contact" class="section footer">
	<div class="container">
		<p class="section-title">聯絡我</p>
		<h2 class="footer__cta">一起做點好東西吧</h2>
		<nav class="footer__links">
			{links.map((l) => <a href={l.href}>{l.label}</a>)}
		</nav>
		<p class="footer__copy">© {year} Sullivan Hsu</p>
	</div>
</footer>

<style>
	.footer__cta {
		font-size: clamp(1.75rem, 5vw, 2.75rem);
		margin: 0 0 2rem;
	}
	.footer__links {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		margin-bottom: 3rem;
	}
	.footer__links a {
		font-size: 1.05rem;
		border-bottom: 1px solid var(--color-border);
		padding-bottom: 2px;
		transition: border-color 0.15s ease;
	}
	.footer__links a:hover {
		border-color: var(--color-text);
	}
	.footer__copy {
		color: var(--color-muted);
		font-size: 0.9rem;
		margin: 0;
	}
</style>
