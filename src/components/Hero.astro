---
// Hero 首屏 —— 依 Figma 設計稿 (node 87:27) 重建。
// 背景格紋與綠光暈用 CSS 畫（清晰、可縮放、零額外圖檔）；QLiEER logo 用原圖。
// 黑框內三句話向上滾動輪播（見下方 <script>）。
const phrases = [
	"把混亂的議題，梳理成值得解決的設計挑戰",
	"透過研究、與使用者交流，去真正了解問題",
	"利用設計在真實場域中創造價值",
];
---

<section id="top" class="hero">
	<img
		src="/quote.svg"
		class="hero__quote hero__quote--tl"
		alt=""
		aria-hidden="true"
	/>
	<img
		src="/quote.svg"
		class="hero__quote hero__quote--br"
		alt=""
		aria-hidden="true"
	/>
	<div class="container hero__content">
		<div class="hero__inner">
		<div class="hero__headline">
			<span class="hero__intro">I'm</span>
			<span class="hero__name">
				<span class="hero__name-text"
					>Sullivan<i class="hero__pin" aria-hidden="true"></i></span
				>
			</span>
			<span class="hero__slash">/</span>
			<span class="hero__role-col">
				<span class="hero__badge">5年經驗</span>
				<span class="hero__role">Product designer</span>
			</span>
		</div>

		<div class="hero__like">
			<span class="hero__like-label">我喜歡</span>
			<span class="hero__rotator" id="hero-rotator">
				<span class="hero__rotator-track">
					{
						phrases.map((p) => (
							<span class="hero__rotator-item">
								<span class="hero__rotator-text">{p}</span>
							</span>
						))
					}
				</span>
			</span>
		</div>

		<div class="hero__current">
			<span class="hero__current-label">現職</span>
			<img
				src="/qlieer-logo.png"
				alt="QLiEER"
				class="hero__logo"
				width="116"
				height="38"
			/>
		</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: calc(100vh - 4rem);
		display: flex;
		align-items: center;
		overflow: hidden;
		background-color: #f7f6fb;
		/* 疊層（由上到下）：右上綠光暈、左下綠光暈、直格線、橫格線、底色 */
		background-image:
			radial-gradient(
				60% 55% at 100% 0%,
				rgba(204, 255, 13, 0.55),
				transparent 60%
			),
			radial-gradient(
				55% 50% at 0% 100%,
				rgba(204, 255, 13, 0.5),
				transparent 60%
			),
			linear-gradient(to right, rgba(0, 0, 0, 0.045) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(0, 0, 0, 0.045) 1px, transparent 1px);
		background-size:
			auto,
			auto,
			22px 22px,
			22px 22px;
	}

	.hero__content {
		position: relative;
		z-index: 1;
	}

	/* 綠色引號裝飾：絕對定位在左上／右下，壓在內容下層 */
	.hero__quote {
		position: absolute;
		z-index: 0;
		width: clamp(70px, 8vw, 130px);
		height: auto;
		pointer-events: none;
	}
	.hero__quote--tl {
		top: 12%;
		left: 5%;
	}
	.hero__quote--br {
		right: 5%;
		bottom: 14%;
		transform: rotate(180deg); /* 開引號轉 180° 成閉引號 */
	}
	/* 手機版：裝飾引號會疊到文字，隱藏較乾淨 */
	@media (max-width: 640px) {
		.hero__quote {
			display: none;
		}
	}

	/* ---------- 主標 ---------- */
	/* 三排彼此靠左（齊頭）；整包由 .hero__inner 置中 */
	.hero__inner {
		width: fit-content;
		max-width: 100%;
		margin-inline: auto;
	}
	.hero__headline {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		gap: 0.8rem 1.2rem;
		margin-bottom: 1.8rem;
	}
	.hero__intro,
	.hero__slash,
	.hero__role {
		font-size: clamp(2.2rem, 6.6vw, 3.9rem);
		font-weight: 300;
		font-style: italic;
		line-height: 1;
		color: #000;
	}

	.hero__name {
		position: relative;
		display: inline-flex;
	}
	.hero__name-text {
		font-size: clamp(2.2rem, 6.6vw, 3.9rem);
		font-weight: 300;
		font-style: italic;
		line-height: 1;
		color: #000;
		/* 實心綠底 */
		background: #ccff0d;
		padding: 0.1em 0.25em;
		/* 抵銷上下 padding 造成的高度，維持與「我是」「/」的基線對齊 */
		margin-block: -0.1em;
		/* 作為 pin 的定位基準，讓 pin 底部能精準貼齊綠底底部 */
		position: relative;
	}
	/* 定位釘小標記：底部貼齊綠底底部，線往上延伸、圓點在頂端 */
	.hero__pin {
		position: absolute;
		bottom: 0;
		right: 0;
		width: 2px;
		height: 1.5em;
		background: #b2df0a;
	}
	.hero__pin::before {
		content: "";
		position: absolute;
		top: -6px;
		left: -3px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #b2df0a;
	}

	/* 5年經驗 + Product designer 直排 */
	.hero__role-col {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.6rem;
	}
	.hero__badge {
		font-size: 1.3rem;
		font-weight: 500;
		color: #000;
		background: #fff;
		border: 2px solid #000;
		border-radius: 37px;
		padding: 0.3em 0.9em;
		line-height: 1;
	}

	/* ---------- 我喜歡 + 黑框 ---------- */
	.hero__like {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0rem;
		margin-bottom: 1.8rem;
	}
	.hero__like-label {
		font-size: clamp(1.3rem, 3.9vw, 2.5rem);
		font-weight: 500;
		color: #000;
		/* 電腦版：把黑框往右推開一點；手機版黑框換行到下方，此 margin 不顯影響 */
		margin-right: 0.8rem;
	}

	/* 輪播窗口：透明遮罩，只負責裁切上下。黑底在每一句身上（見 item）。 */
	.hero__rotator {
		display: inline-block;
		overflow: hidden;
		vertical-align: bottom;
		max-width: 100%;
		width: max-content; /* 寬度 = 最寬那句黑底，較短的靠左、右側露出背景 */
		font-size: clamp(1.4rem, 4vw, 2.8rem);
		font-weight: 700;
		line-height: 1.25;
		/* 高度由 JS 設定（貼合當前句），切換時平滑縮放 */
		transition: height 0.55s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.hero__rotator-track {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5em; /* 句子之間的間隔（滑動時會露出背景） */
		transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.hero__rotator-track.is-instant {
		transition: none;
	}
	/* 每一句的排版容器：桌機一行、行動版可換行 */
	.hero__rotator-item {
		white-space: nowrap;
		width: max-content;
		line-height: 1.25;
	}
	/* 黑底套在文字上；box-decoration-break 讓換行時每一行各自成獨立黑塊 */
	.hero__rotator-text {
		background: #000;
		color: #fff;
		padding: 0.2em 0.35em;
		-webkit-box-decoration-break: clone;
		box-decoration-break: clone;
	}

	/* 手機版：窗口滿版、長句換行，每行各自黑塊、拉開行距使黑塊分開 */
	@media (max-width: 640px) {
		.hero__inner {
			width: 100%;
		}
		.hero__rotator {
			width: 100%;
		}
		.hero__rotator-item {
			white-space: normal;
			width: 100%;
			line-height: 1.9;
		}
	}

	/* 尊重「減少動態」偏好：關掉滑動與伸縮，改直接切換 */
	@media (prefers-reduced-motion: reduce) {
		.hero__rotator,
		.hero__rotator-track {
			transition: none;
		}
	}

	/* ---------- 現職 QLiEER ---------- */
	.hero__current {
		display: flex;
		align-items: center;
		gap: 0.3rem;
	}
	.hero__current-label {
		font-size: clamp(1.1rem, 2.2vw, 1.4rem);
		color: #000;
	}
	.hero__logo {
		height: 2.2rem;
		width: auto;
	}

	/* 手機版：定位釘在窄螢幕會浮空，藏起來較乾淨 */
	@media (max-width: 640px) {
		.hero__pin {
			display: none;
		}
	}
</style>

<script>
	// 黑框三句話「向上滾動」輪播，寬度平滑跟著文字伸縮，每 3 秒切換。
	function initRotator() {
		const rotator = document.getElementById("hero-rotator");
		if (!rotator) return;
		const track = rotator.querySelector<HTMLElement>(".hero__rotator-track");
		if (!track) return;

		const originals = Array.from(
			track.querySelectorAll<HTMLElement>(".hero__rotator-item"),
		);
		if (originals.length < 2) return;

		// 在最後補一個「第一句」的複製，讓循環永遠向上、不會倒退跳回。
		const clone = originals[0].cloneNode(true) as HTMLElement;
		track.appendChild(clone);
		const items = [...originals, clone];

		let index = 0;

		// 各句相對第一句的位置與高度（可容納「有的一行、有的兩行」的高度差）
		const relTop = (i: number) => items[i].offsetTop - items[0].offsetTop;
		const heightOf = (i: number) => items[i].getBoundingClientRect().height;
		const gapBetween = () =>
			items.length > 1 ? relTop(1) - heightOf(0) : 0;
		// 窗口高度貼合「當前這句」＋一點間隔：短句窗口矮、長句高，鄰句永遠藏在外面
		const viewportHeightFor = (i: number) => heightOf(i) + gapBetween();
		// 讓第 i 句在窗口內置中（上下各留 gap/2）
		const offsetFor = (i: number) => gapBetween() / 2 - relTop(i);

		// 套用第 i 句的窗口高度與位置；instant=true 時瞬間套用（無動畫）
		const apply = (i: number, instant: boolean) => {
			if (instant) {
				track.style.transition = "none";
				rotator.style.transition = "none";
			}
			rotator.style.height = viewportHeightFor(i) + "px";
			track.style.transform = `translateY(${offsetFor(i)}px)`;
			if (instant) {
				void track.offsetHeight; // 強制重繪後恢復動畫
				track.style.transition = "";
				rotator.style.transition = "";
			}
		};

		const sync = () => apply(index, true);
		sync();

		const advance = () => {
			index += 1;
			apply(index, false);

			// 滑到複製的第一句後，無動畫瞬間跳回真正的第一句，接續下一輪
			if (index === items.length - 1) {
				window.setTimeout(() => {
					index = 0;
					apply(index, true);
				}, 600);
			}
		};

		window.setInterval(advance, 3000);
		window.addEventListener("resize", sync);
	}

	initRotator();
</script>
