---
// Hero 首屏 —— 依 Figma 設計稿 (node 87:27) 重建。
// 背景格紋與綠光暈用 CSS 畫（清晰、可縮放、零額外圖檔）；QLiEER logo 用原圖。
// 黑框內三句話用「打字機」效果打字→停留→刪除→打下一句（見下方 <script>）。
const phrases = [
	"把混亂的議題，梳理成值得解決的設計挑戰",
	"透過研究、與使用者交流，去真正了解問題",
	"利用設計在真實場域中創造價值",
];
// 最長的一句 —— 當隱形佔位，先撐住寬高，打字時整塊不會位移
const longest = phrases.reduce((a, b) => (b.length >= a.length ? b : a), phrases[0]);
---

<section id="top" class="hero">
	<img
		src="/quote.svg"
		class="hero__quote hero__quote--tl"
		alt=""
		aria-hidden="true"
	/>
	<img
		src="/quote.svg"
		class="hero__quote hero__quote--br"
		alt=""
		aria-hidden="true"
	/>
	<div class="container hero__content">
		<div class="hero__inner">
		<div class="hero__headline">
			<span class="hero__intro">I'm</span>
			<span class="hero__name">
				<span class="hero__name-text"
					>Sullivan<i class="hero__pin" aria-hidden="true"></i></span
				>
			</span>
			<span class="hero__slash">/</span>
			<span class="hero__role-col">
				<span class="hero__badge">5年經驗</span>
				<span class="hero__role">Product designer</span>
			</span>
		</div>

		<div class="hero__like">
			<span class="hero__like-label">我喜歡</span>
			<span class="hero__tw" id="hero-tw">
				<span class="hero__tw-sizer" aria-hidden="true">{longest}_</span>
				<span class="hero__tw-box"
					><span class="hero__tw-content"
						><span class="hero__tw-text"></span
						><span class="hero__tw-cursor" aria-hidden="true">_</span></span
					></span
				>
			</span>
		</div>

		<div class="hero__current">
			<span class="hero__current-label">現職</span>
			<img
				src="/qlieer-logo.png"
				alt="QLiEER"
				class="hero__logo"
				width="116"
				height="38"
			/>
		</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: calc(100vh - 4rem);
		display: flex;
		align-items: center;
		overflow: hidden;
		background-color: #f7f6fb;
		/* 疊層（由上到下）：右上綠光暈、左下綠光暈、直格線、橫格線、底色 */
		background-image:
			radial-gradient(
				60% 55% at 100% 0%,
				rgba(204, 255, 13, 0.55),
				transparent 60%
			),
			radial-gradient(
				55% 50% at 0% 100%,
				rgba(204, 255, 13, 0.5),
				transparent 60%
			),
			linear-gradient(to right, rgba(0, 0, 0, 0.045) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(0, 0, 0, 0.045) 1px, transparent 1px);
		background-size:
			auto,
			auto,
			22px 22px,
			22px 22px;
	}

	.hero__content {
		position: relative;
		z-index: 1;
	}

	/* 綠色引號裝飾：絕對定位在左上／右下，壓在內容下層 */
	.hero__quote {
		position: absolute;
		z-index: 0;
		width: clamp(70px, 8vw, 130px);
		height: auto;
		pointer-events: none;
	}
	.hero__quote--tl {
		top: 12%;
		left: 5%;
	}
	.hero__quote--br {
		right: 5%;
		bottom: 14%;
		transform: rotate(180deg); /* 開引號轉 180° 成閉引號 */
	}
	/* 手機版：裝飾引號會疊到文字，隱藏較乾淨 */
	@media (max-width: 640px) {
		.hero__quote {
			display: none;
		}
	}

	/* ---------- 主標 ---------- */
	/* 三排彼此靠左（齊頭）；整包由 .hero__inner 置中 */
	.hero__inner {
		width: fit-content;
		max-width: 100%;
		margin-inline: auto;
	}
	.hero__headline {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		gap: 0.8rem 1.2rem;
		margin-bottom: 1.8rem;
	}
	.hero__intro,
	.hero__slash,
	.hero__role {
		font-size: clamp(2.2rem, 6.6vw, 3.9rem);
		font-weight: 300;
		font-style: italic;
		line-height: 1;
		color: #000;
	}

	.hero__name {
		position: relative;
		display: inline-flex;
	}
	.hero__name-text {
		font-size: clamp(2.2rem, 6.6vw, 3.9rem);
		font-weight: 300;
		font-style: italic;
		line-height: 1;
		color: #000;
		/* 實心綠底 */
		background: #ccff0d;
		padding: 0.1em 0.25em;
		/* 抵銷上下 padding 造成的高度，維持與「我是」「/」的基線對齊 */
		margin-block: -0.1em;
		/* 作為 pin 的定位基準，讓 pin 底部能精準貼齊綠底底部 */
		position: relative;
	}
	/* 定位釘小標記：底部貼齊綠底底部，線往上延伸、圓點在頂端 */
	.hero__pin {
		position: absolute;
		bottom: 0;
		right: 0;
		width: 2px;
		height: 1.5em;
		background: #b2df0a;
	}
	.hero__pin::before {
		content: "";
		position: absolute;
		top: -6px;
		left: -3px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #b2df0a;
	}

	/* 5年經驗 + Product designer 直排 */
	.hero__role-col {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.6rem;
	}
	.hero__badge {
		font-size: 1.3rem;
		font-weight: 500;
		color: #000;
		background: #fff;
		border: 2px solid #000;
		border-radius: 37px;
		padding: 0.3em 0.9em;
		line-height: 1;
	}

	/* ---------- 我喜歡 + 黑框 ---------- */
	.hero__like {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline; /* 用文字基線對齊「我喜歡」與黑框內文字 */
		gap: 0rem;
		margin-bottom: 1.8rem;
	}
	.hero__like-label {
		font-size: clamp(1.3rem, 3.9vw, 2.5rem);
		font-weight: 500;
		color: #000;
		/* 電腦版：把黑框往右推開一點；手機版黑框換行到下方，此 margin 不顯影響 */
		margin-right: 0.8rem;
	}

	/* 打字機黑框：隱形 sizer（最長句）在流內撐住寬高並提供文字基線；
	   真正的黑框用絕對定位疊在上面，不影響基線，打字時整塊不位移 */
	.hero__tw {
		position: relative;
		display: inline-block;
		max-width: 100%;
		font-size: clamp(1.4rem, 4vw, 2.8rem);
		font-weight: 700;
		line-height: 1.25;
	}
	.hero__tw-sizer,
	.hero__tw-box {
		white-space: nowrap;
	}
	.hero__tw-sizer {
		visibility: hidden; /* 只佔位撐住寬高、提供基線，不顯示 */
		padding: 0.2em 0.35em; /* 與黑框 padding 一致，寬度才對得上 */
	}
	.hero__tw-box {
		position: absolute; /* 疊在 sizer 之上，不影響 .hero__tw 的文字基線 */
		top: 0;
		left: 0;
	}
	/* 黑底套在文字+游標上；box-decoration-break 讓換行時每行各自成獨立黑塊 */
	.hero__tw-content {
		background: #000;
		color: #fff;
		padding: 0.2em 0.35em;
		-webkit-box-decoration-break: clone;
		box-decoration-break: clone;
	}
	.hero__tw-cursor {
		animation: tw-blink 1s step-end infinite;
	}
	@keyframes tw-blink {
		0%,
		50% {
			opacity: 1;
		}
		50.01%,
		100% {
			opacity: 0;
		}
	}

	/* 手機版：滿版、長句換行，每行各自黑塊、拉開行距使黑塊分開 */
	@media (max-width: 640px) {
		.hero__inner {
			width: 100%;
		}
		.hero__tw {
			width: 100%;
		}
		.hero__tw-sizer,
		.hero__tw-box {
			white-space: normal;
		}
		.hero__tw-sizer,
		.hero__tw-content {
			line-height: 1.9;
		}
	}

	/* 尊重「減少動態」偏好：關掉游標閃爍（打字動畫由 JS 端略過） */
	@media (prefers-reduced-motion: reduce) {
		.hero__tw-cursor {
			animation: none;
		}
	}

	/* ---------- 現職 QLiEER ---------- */
	.hero__current {
		display: flex;
		align-items: center;
		gap: 0.3rem;
	}
	.hero__current-label {
		font-size: clamp(1.1rem, 2.2vw, 1.4rem);
		color: #000;
	}
	.hero__logo {
		height: 2.2rem;
		width: auto;
	}

	/* 手機版：定位釘在窄螢幕會浮空，藏起來較乾淨 */
	@media (max-width: 640px) {
		.hero__pin {
			display: none;
		}
	}
</style>

<script define:vars={{ phrases }}>
	// 打字機效果：逐字打出 → 停留 → 逐字刪除 → 換下一句，循環不斷。
	function initTypewriter() {
		const box = document.getElementById("hero-tw");
		if (!box) return;
		const textEl = box.querySelector(".hero__tw-text");
		if (!textEl) return;

		// 尊重「減少動態」偏好：不跑打字動畫，直接顯示第一句
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
			textEl.textContent = phrases[0];
			return;
		}

		const TYPE = 110; // 每個字打出的間隔（毫秒）
		const DELETE = 55; // 每個字刪除的間隔
		const HOLD = 2500; // 整句打完後停留
		const GAP = 500; // 刪完到打下一句之間

		let phraseIndex = 0;
		let charIndex = 0;
		let deleting = false;

		const tick = () => {
			const phrase = phrases[phraseIndex];
			if (!deleting) {
				charIndex += 1;
				textEl.textContent = phrase.slice(0, charIndex);
				if (charIndex >= phrase.length) {
					deleting = true;
					window.setTimeout(tick, HOLD);
				} else {
					window.setTimeout(tick, TYPE);
				}
			} else {
				charIndex -= 1;
				textEl.textContent = phrase.slice(0, charIndex);
				if (charIndex <= 0) {
					deleting = false;
					phraseIndex = (phraseIndex + 1) % phrases.length;
					window.setTimeout(tick, GAP);
				} else {
					window.setTimeout(tick, DELETE);
				}
			}
		};

		window.setTimeout(tick, TYPE);
	}

	initTypewriter();
</script>
