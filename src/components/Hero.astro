---
// Hero 首屏 —— 依 Figma 設計稿 (node 87:27) 重建。
// 背景格紋與綠光暈用 CSS 畫（清晰、可縮放、零額外圖檔）；QLiEER logo 用原圖。
// 黑框內三句話向上滾動輪播（見下方 <script>）。
const phrases = [
	"把混亂的議題，梳理成值得解決的設計挑戰",
	"透過研究、與使用者交流，去真正了解問題",
	"利用設計在真實場域中創造價值",
];
---

<section id="top" class="hero">
	<div class="container hero__content">
		<div class="hero__headline">
			<span class="hero__intro">我是</span>
			<span class="hero__name">
				<span class="hero__name-text">Sullivan</span>
				<i class="hero__pin" aria-hidden="true"></i>
			</span>
			<span class="hero__slash">/</span>
			<span class="hero__role-col">
				<span class="hero__badge">5年經驗</span>
				<span class="hero__role">Product designer</span>
			</span>
		</div>

		<div class="hero__like">
			<span class="hero__like-label">我喜歡</span>
			<span class="hero__rotator" id="hero-rotator">
				<span class="hero__rotator-track">
					{phrases.map((p) => <span class="hero__rotator-item">{p}</span>)}
				</span>
			</span>
		</div>

		<div class="hero__current">
			<span class="hero__current-label">現職</span>
			<img
				src="/qlieer-logo.png"
				alt="QLiEER"
				class="hero__logo"
				width="116"
				height="38"
			/>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: calc(100vh - 4rem);
		display: flex;
		align-items: center;
		overflow: hidden;
		background-color: #f7f6fb;
		/* 疊層（由上到下）：右上綠光暈、左下綠光暈、直格線、橫格線、底色 */
		background-image:
			radial-gradient(
				60% 55% at 100% 0%,
				rgba(204, 255, 13, 0.55),
				transparent 60%
			),
			radial-gradient(
				55% 50% at 0% 100%,
				rgba(204, 255, 13, 0.5),
				transparent 60%
			),
			linear-gradient(to right, rgba(0, 0, 0, 0.045) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(0, 0, 0, 0.045) 1px, transparent 1px);
		background-size:
			auto,
			auto,
			44px 44px,
			44px 44px;
	}

	.hero__content {
		position: relative;
		z-index: 1;
	}

	/* ---------- 主標 ---------- */
	.hero__headline {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		gap: 0.75rem 1.1rem;
		margin-bottom: 1.6rem;
	}
	.hero__intro,
	.hero__slash,
	.hero__role {
		font-size: clamp(2rem, 6vw, 3.5rem);
		font-weight: 700;
		line-height: 1;
		color: #000;
	}

	.hero__name {
		position: relative;
		display: inline-flex;
	}
	.hero__name-text {
		font-size: clamp(2rem, 6vw, 3.5rem);
		font-weight: 700;
		line-height: 1;
		color: #000;
		/* 螢光綠 highlight：只塗文字下半部，像螢光筆劃過 */
		background: linear-gradient(
			transparent 38%,
			#ccff0d 38%,
			#ccff0d 92%,
			transparent 92%
		);
		padding-inline: 0.1em;
	}
	/* 定位釘小標記 */
	.hero__pin {
		position: absolute;
		top: -0.9em;
		right: -0.15em;
		width: 2px;
		height: 1.5em;
		background: #000;
	}
	.hero__pin::before {
		content: "";
		position: absolute;
		top: -5px;
		left: -3px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #000;
	}

	/* 5年經驗 + Product designer 直排 */
	.hero__role-col {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
	}
	.hero__badge {
		font-size: clamp(0.95rem, 2.2vw, 1.5rem);
		font-weight: 500;
		color: #000;
		background: #fff;
		border: 2px solid #000;
		border-radius: 37px;
		padding: 0.3em 0.9em;
		line-height: 1;
	}

	/* ---------- 我喜歡 + 黑框 ---------- */
	.hero__like {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.7rem;
		margin-bottom: 1.6rem;
	}
	.hero__like-label {
		font-size: clamp(1.2rem, 3.5vw, 2.25rem);
		font-weight: 500;
		color: #000;
	}

	/* 輪播窗口：透明遮罩，只負責裁切上下。黑底在每一句身上（見 item）。 */
	.hero__rotator {
		display: inline-block;
		overflow: hidden;
		vertical-align: bottom;
		max-width: 100%;
		width: max-content; /* 寬度 = 最寬那句黑底，較短的靠左、右側露出背景 */
		font-size: clamp(1.25rem, 3.6vw, 2.5rem);
		font-weight: 700;
		line-height: 1.25;
		/* 高度由 JS 設定（一句黑底高 + 間隔） */
	}
	.hero__rotator-track {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5em; /* 句子之間的間隔（滑動時會露出背景） */
		transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.hero__rotator-track.is-instant {
		transition: none;
	}
	/* 每一句 = 自己的黑底，文字與黑底一體、一起移動 */
	.hero__rotator-item {
		white-space: nowrap;
		width: max-content;
		background: #000;
		color: #fff;
		padding: 0.2em 0.35em;
		line-height: 1.25;
	}

	/* 尊重「減少動態」偏好：關掉滑動與伸縮，改直接切換 */
	@media (prefers-reduced-motion: reduce) {
		.hero__rotator,
		.hero__rotator-track {
			transition: none;
		}
	}

	/* ---------- 現職 QLiEER ---------- */
	.hero__current {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}
	.hero__current-label {
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: #000;
	}
	.hero__logo {
		height: 2rem;
		width: auto;
	}

	/* 手機版：定位釘在窄螢幕會浮空，藏起來較乾淨 */
	@media (max-width: 640px) {
		.hero__pin {
			display: none;
		}
	}
</style>

<script>
	// 黑框三句話「向上滾動」輪播，寬度平滑跟著文字伸縮，每 3 秒切換。
	function initRotator() {
		const rotator = document.getElementById("hero-rotator");
		if (!rotator) return;
		const track = rotator.querySelector<HTMLElement>(".hero__rotator-track");
		if (!track) return;

		const originals = Array.from(
			track.querySelectorAll<HTMLElement>(".hero__rotator-item"),
		);
		if (originals.length < 2) return;

		// 在最後補一個「第一句」的複製，讓循環永遠向上、不會倒退跳回。
		const clone = originals[0].cloneNode(true) as HTMLElement;
		track.appendChild(clone);
		const items = [...originals, clone];

		let index = 0;

		// 黑底句子的高度、以及「一句 + 一間隔」的步距（pitch）
		const boxHeight = () => originals[0].getBoundingClientRect().height;
		const pitch = () =>
			items.length > 1
				? items[1].offsetTop - items[0].offsetTop
				: boxHeight();
		const gap = () => pitch() - boxHeight();

		// 目前這句要落在窗口的位置：垂直置中（上下各留 gap/2）
		const offsetFor = (i: number) => -(pitch() * i) + gap() / 2;

		// 依目前字級設定窗口高度（一句黑底 + 一個間隔）與初始位置
		const sync = () => {
			rotator.style.height = boxHeight() + gap() + "px";
			track.classList.add("is-instant");
			track.style.transform = `translateY(${offsetFor(index)}px)`;
			void track.offsetHeight; // 強制重繪後恢復動畫
			track.classList.remove("is-instant");
		};
		sync();

		const advance = () => {
			index += 1;
			track.style.transform = `translateY(${offsetFor(index)}px)`;

			// 滑到複製的第一句後，無動畫瞬間跳回真正的第一句，接續下一輪
			if (index === items.length - 1) {
				window.setTimeout(() => {
					track.classList.add("is-instant");
					index = 0;
					track.style.transform = `translateY(${offsetFor(0)}px)`;
					void track.offsetHeight;
					track.classList.remove("is-instant");
				}, 600);
			}
		};

		window.setInterval(advance, 3000);
		window.addEventListener("resize", sync);
	}

	initRotator();
</script>
